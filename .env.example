# Canonical site
NEXT_PUBLIC_SITE_URL=https://Protonecarehospital.com

# Admin security - required before production launch
ADMIN_SESSION_SECRET=replace-with-long-random-secret
ADMIN_SUPER_EMAIL=superadmin@protonecarehospital.com
# Bootstrap-only secret. Minimum 15 characters. D1 remains authoritative after first creation.
ADMIN_SUPER_PASSWORD=replace-with-15-plus-character-passphrase

# Cloudflare Turnstile - appointment and feedback forms
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# Firebase Phone Auth
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-auth-domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-storage-bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Sites bindings are declared in .openai/hosting.json
# D1 binding: DB
# R2 binding: MEDIA
