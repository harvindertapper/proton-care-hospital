# Canonical site
NEXT_PUBLIC_SITE_URL=https://protonecarehospital.com

# Admin security - required before production launch
ADMIN_SESSION_SECRET=replace-with-long-random-secret
ADMIN_SUPER_EMAIL=superadmin@protonecarehospital.com
# Bootstrap-only secret. Minimum 15 characters. D1 remains authoritative after
# first creation; changing this later has no effect while an active super admin
# exists. Recovery: deactivate the row in D1 (is_active = 0), set a new value
# here, and the next login reactivates the account with it. See README.
ADMIN_SUPER_PASSWORD=replace-with-15-plus-character-passphrase

# Auth/encryption secret (used alongside ADMIN_SESSION_SECRET for session crypto).
AUTH_SECRET=replace-with-another-long-random-secret
# Resend API key for transactional admin emails (OTP, staff onboarding).
RESEND_API_KEY=replace-with-resend-api-key
# Super admin recovery window flag. Leave UNSET in steady state. Set to "true"
# only during a verified lockout-recovery window, then delete. See README.
ENABLE_SUPER_ADMIN_RECOVERY=

# Cloudflare Turnstile - appointment and feedback forms
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# Cloudflare bindings are declared in wrangler.jsonc:
# D1 binding: DB (site-creator-d1)
# R2 binding: MEDIA (pch)
# Images binding: IMAGES
