# Canonical site
NEXT_PUBLIC_SITE_URL=https://Protonecarehospital.com

# Admin security - required before production launch
ADMIN_SESSION_SECRET=replace-with-long-random-secret
ADMIN_SUPER_EMAIL=superadmin@protonecarehospital.com
ADMIN_SUPER_PASSWORD=replace-with-strong-password
ADMIN_STAFF_EMAIL=staff@protonecarehospital.com
ADMIN_STAFF_PASSWORD=replace-with-strong-password

# Cloudflare Turnstile - appointment and feedback forms
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace-with-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-turnstile-secret-key

# SMS91 / MSG91 OTP
SMS91_AUTH_KEY=replace-with-msg91-auth-key
SMS91_OTP_TEMPLATE_ID=replace-with-approved-template-id
SMS91_SENDER_ID=replace-with-approved-sender-id
OTP_HASH_SECRET=replace-with-long-random-secret

# Sites bindings are declared in .openai/hosting.json
# D1 binding: DB
# R2 binding: MEDIA
